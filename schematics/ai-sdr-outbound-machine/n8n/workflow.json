        ]
      ]
    },
    "Approved?": {
      "main": [
        [
          {
            "node": "Emit Result Event",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Emit Blocked Event",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
