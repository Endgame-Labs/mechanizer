{
  "name": "deal-hygiene-machine-v1",
  "machine_id": "deal-hygiene-machine",
  "version": "1.1.0",
  "trigger": {
    "type": "callable",
    "operation": "trigger",
    "input_schema": "gtm_event_v1",
    "accepts_event_types": [
      "deal.updated",
      "call.completed",
      "account.health_changed"
    ]
  },
  "config": {
    "slo": {
      "p95_end_to_end_seconds": 120
    },
    "idempotency_key": "event_id",
    "approval_required_before_writes": true,
    "timeouts": {
      "http_step_seconds": 20,
      "approval_wait_seconds": 1800
    }
  },
  "steps": [
    {
      "id": "normalize_validate",
      "type": "script",
      "script": "assert_required_gtm_event_v1_fields"
    },
    {
      "id": "idempotency_check",
      "type": "data_storage.get",
      "key": "deal-hygiene:${steps.normalize_validate.output.event_id}"
    },
    {
      "id": "enrich_account_health",
      "type": "http.client",
      "method": "POST",
      "url": "https://cogs.internal/enrich_account_health/v1/execute",
      "body_path": "steps.normalize_validate.output"
    },
    {
      "id": "deal_score_reasoner",
      "type": "http.client",
      "method": "POST",
      "url": "https://cogs.internal/deal_score_reasoner/v1/execute",
      "body_path": "steps.enrich_account_health.output"
    },
    {
      "id": "directive_alignment",
      "type": "http.client",
      "method": "POST",
      "url": "https://cogs.internal/directive_alignment/v1/execute",
      "body_path": "steps.deal_score_reasoner.output"
    },
    {
      "id": "route_exec_alert",
      "type": "http.client",
      "method": "POST",
      "url": "https://cogs.internal/route_exec_alert/v1/execute",
      "body_path": "steps.directive_alignment.output"
    },
    {
      "id": "approval_loop",
      "type": "http.client",
      "method": "POST",
      "url": "https://approvals.internal/v1/request",
      "body_path": "steps.route_exec_alert.output"
    },
    {
      "id": "approval_branch",
      "type": "branch",
      "conditions": [
        {
          "name": "approved",
          "expression": "steps.approval_loop.output.attributes.approval_status == 'approved'"
        },
        {
          "name": "deferred",
          "expression": "steps.approval_loop.output.attributes.approval_status != 'approved'"
        }
      ]
    },
    {
      "id": "sfdc_writeback",
      "type": "salesforce.update_record",
      "branch": "approved",
      "object": "Opportunity",
      "record_id_path": "steps.approval_loop.output.subject.opportunity_id",
      "field_map": {
        "CloseDate": "steps.approval_loop.output.attributes.proposed_mutations.close_date",
        "NextStep": "steps.approval_loop.output.attributes.proposed_mutations.next_step"
      },
      "error_handling": "manual"
    },
    {
      "id": "emit_output_event",
      "type": "http.client",
      "method": "POST",
      "url": "https://events.internal/v1/publish",
      "body_template": {
        "schema_version": "gtm_event_v1",
        "event_id": "{{steps.normalize_validate.output.event_id}}",
        "event_type": "{{branch == 'approved' ? 'deal.hygiene.remediated' : 'deal.hygiene.deferred'}}",
        "source": "tray",
        "occurred_at": "{{steps.normalize_validate.output.occurred_at}}",
        "ingested_at": "{{now}}",
        "trace": {
          "trace_id": "{{steps.normalize_validate.output.trace.trace_id}}",
          "run_id": "{{workflow.run_id}}"
        },
        "subject": "{{steps.normalize_validate.output.subject}}",
        "attributes": "{{steps.approval_loop.output.attributes}}"
      }
    },
    {
      "id": "idempotency_store",
      "type": "data_storage.put",
      "key": "deal-hygiene:${steps.normalize_validate.output.event_id}",
      "value": {
        "terminal_event_type": "{{steps.emit_output_event.request.body.event_type}}",
        "updated_at": "{{now}}"
      }
    }
  ],
  "error_handling": {
    "default_step_mode": "automatic",
    "manual_paths_for": [
      "sfdc_writeback"
    ],
    "dead_letter_target": "deal-hygiene-machine-dlq",
    "alerting": {
      "required_fields": [
        "workflow_uuid",
        "step_name",
        "step_log_url",
        "message"
      ]
    }
  },
  "sdlc": {
    "project_versioning": {
      "enabled": true,
      "annotate_versions": true
    },
    "import_export": {
      "unit": "project",
      "json_artifact": true,
      "manual_first_prod_import": true
    },
    "promotion": {
      "flow": [
        "dev_test",
        "save_version",
        "export",
        "import",
        "requirements_check",
        "preview",
        "publish"
      ]
    }
  }
}
