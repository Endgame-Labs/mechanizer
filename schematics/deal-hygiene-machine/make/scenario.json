{
  "name": "deal-hygiene-machine-v2",
  "machine_id": "deal-hygiene-machine",
  "artifact_type": "make_scenario_blueprint_reference",
  "make_runtime": {
    "blueprint": {
      "max_import_size_mb": 2
    },
    "scheduling": {
      "mode": "instant_webhook_plus_periodic_sweep",
      "webhook_path": "deal-hygiene-machine",
      "periodic_sweep_interval_minutes": 30,
      "max_runs_per_minute": 45,
      "sequential_processing": true
    },
    "retry_model": {
      "store_incomplete_executions": true,
      "auto_retry_errors": [
        "RateLimitError",
        "ConnectionError",
        "ModuleTimeoutError"
      ],
      "retry_schedule": [
        "1m",
        "10m",
        "10m",
        "30m",
        "30m",
        "30m",
        "3h",
        "3h"
      ],
      "parallel_retry_limit_per_scenario": 3
    }
  },
  "trigger_paths": [
    {
      "type": "webhook",
      "module": "webhooks:customWebhook",
      "path": "deal-hygiene-machine",
      "accepts_event_types": [
        "deal.updated",
        "call.completed",
        "account.health_changed"
      ]
    },
    {
      "type": "schedule",
      "module": "scheduler:atRegularIntervals",
      "interval_minutes": 30,
      "purpose": "backfill_and_drift_scan"
    }
  ],
  "modules": [
    {
      "id": 1,
      "module": "json:createJSON",
      "name": "Normalize gtm_event_v1"
    },
    {
      "id": 2,
      "module": "datastore:getARecord",
      "name": "Idempotency Lookup",
      "parameters": {
        "store": "deal_hygiene_runs",
        "key": "deal-hygiene:{{1.event_id}}"
      }
    },
    {
      "id": 3,
      "module": "flow:filter",
      "name": "Skip Duplicates",
      "filter": "{{empty(2.value)}}"
    },
    {
      "id": 4,
      "module": "http:makeRequest",
      "name": "Fetch Context",
      "parameters": {
        "url": "https://context.internal/deal-hygiene/enrich",
        "method": "POST",
        "body": "{{toJSON(1)}}"
      }
    },
    {
      "id": 5,
      "module": "http:makeRequest",
      "name": "Deal Score Reasoner",
      "parameters": {
        "url": "https://cogs.internal/deal_score_reasoner/v1/execute",
        "method": "POST",
        "body": "{{4.body}}"
      }
    },
    {
      "id": 6,
      "module": "flow:router",
      "name": "Severity Router",
      "routes": [
        {
          "name": "critical",
          "condition": "{{5.body.score}} >= 80"
        },
        {
          "name": "standard",
          "condition": "{{5.body.score}} >= 60"
        },
        {
          "name": "monitor",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 7,
      "module": "tools:arrayAggregator",
      "name": "Aggregate Proposed Mutations",
      "parameters": {
        "source": "6",
        "target_structure": "proposed_mutations[]"
      }
    },
    {
      "id": 8,
      "module": "http:makeRequest",
      "name": "Approval Loop",
      "parameters": {
        "url": "https://approval.internal/request",
        "method": "POST",
        "body": "{\"event_id\":\"{{1.event_id}}\",\"subject\":{{1.subject}},\"proposed_mutations\":{{7.array}},\"timeout_seconds\":1800}"
      }
    },
    {
      "id": 9,
      "module": "flow:router",
      "name": "Approval Router",
      "routes": [
        {
          "name": "approved",
          "condition": "{{8.body.approval_status}} = approved"
        },
        {
          "name": "deferred",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 10,
      "module": "salesforce:updateARecord",
      "name": "Update Opportunity",
      "route": "approved",
      "parameters": {
        "object": "Opportunity",
        "record_id": "{{1.subject.id}}"
      }
    },
    {
      "id": 11,
      "module": "http:makeRequest",
      "name": "Emit Outcome Event",
      "parameters": {
        "url": "https://events.internal/emit",
        "method": "POST",
        "body": "{\"event_type\":\"{{if(9.route = \\\"approved\\\"; \\\"deal.hygiene.remediated\\\"; \\\"deal.hygiene.deferred\\\")}}\",\"event_id\":\"{{1.event_id}}\",\"trace\":{{1.trace}}}"
      }
    },
    {
      "id": 12,
      "module": "datastore:addOrReplaceARecord",
      "name": "Write Run Summary",
      "parameters": {
        "store": "deal_hygiene_runs",
        "key": "deal-hygiene:{{1.event_id}}"
      }
    }
  ],
  "error_handlers": [
    {
      "on": [
        "http:makeRequest",
        "salesforce:updateARecord"
      ],
      "strategy": "break_with_incomplete_execution_retry",
      "dead_letter_module": "http:makeRequest",
      "dead_letter_url": "https://events.internal/dead-letter"
    }
  ]
}
