{
  "zap_name": "Deal Hygiene Machine",
  "version": "1.2.0",
  "machine_id": "deal-hygiene-machine",
  "description": "Approval-gated deal hygiene remediation for CRM data quality and stage integrity.",
  "trigger": {
    "primary": {
      "app": "webhooks_by_zapier",
      "event": "catch_hook",
      "path": "/deal-hygiene/events"
    },
    "alternate": {
      "app": "salesforce",
      "event": "updated_record",
      "object": "Opportunity"
    },
    "accepts_event_types": [
      "deal.updated",
      "call.completed",
      "account.health_changed"
    ]
  },
  "gtm_event_v1_mapping": {
    "required": [
      "schema_version",
      "event_id",
      "event_type",
      "source",
      "occurred_at",
      "ingested_at",
      "trace",
      "subject",
      "attributes"
    ],
    "notes": "Preserve non-canonical fields under raw."
  },
  "steps": [
    {
      "id": "normalize_validate",
      "app": "code_by_zapier",
      "event": "run_javascript"
    },
    {
      "id": "filter_supported_events",
      "app": "filter_by_zapier",
      "event": "only_continue_if",
      "rule": "event_type in ['deal.updated','call.completed','account.health_changed']"
    },
    {
      "id": "idempotency_lookup",
      "app": "storage_by_zapier",
      "event": "get_value",
      "key_template": "deal-hygiene:${event_id}"
    },
    {
      "id": "fetch_context",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://context.internal/deal-hygiene/enrich",
        "json": {
          "event": "{{trigger.raw_body}}",
          "context_providers": [
            "endgame_mcp_or_cli",
            "salesforce_headless_360",
            "call_intelligence_provider"
          ]
        }
      }
    },
    {
      "id": "deal_score_reasoner",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://cogs.internal/deal_score_reasoner/v1/execute"
      }
    },
    {
      "id": "directive_alignment",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://cogs.internal/directive_alignment/v1/execute"
      }
    },
    {
      "id": "compose_proposed_changes",
      "app": "code_by_zapier",
      "event": "run_javascript",
      "purpose": "Build deterministic field diffs for Opportunity update payload."
    },
    {
      "id": "approval_loop",
      "app": "human_in_the_loop",
      "event": "request_approval",
      "fallback": {
        "app": "webhooks_by_zapier",
        "event": "post",
        "url": "https://approval.internal/request"
      },
      "request_payload": {
        "event_id": "{{event_id}}",
        "opportunity_id": "{{subject.id}}",
        "proposed_mutations": "{{steps.compose_proposed_changes.output}}",
        "risk_score": "{{steps.deal_score_reasoner.body.score}}"
      }
    },
    {
      "id": "path_on_approval",
      "app": "paths_by_zapier",
      "event": "branch",
      "paths": [
        {
          "name": "approved",
          "condition": "approval_status == 'approved'",
          "actions": [
            {
              "id": "sfdc_writeback",
              "app": "salesforce",
              "event": "update_record",
              "object": "Opportunity",
              "idempotency_key": "{{event_id}}"
            },
            {
              "id": "emit_approved",
              "app": "webhooks_by_zapier",
              "event": "post",
              "request": {
                "url": "https://events.internal/publish",
                "json": {
                  "event_type": "deal.hygiene.remediated"
                }
              }
            }
          ]
        },
        {
          "name": "blocked",
          "condition": "approval_status != 'approved'",
          "actions": [
            {
              "id": "notify_blocked",
              "app": "slack",
              "event": "send_channel_message"
            },
            {
              "id": "emit_blocked",
              "app": "webhooks_by_zapier",
              "event": "post",
              "request": {
                "url": "https://events.internal/publish",
                "json": {
                  "event_type": "deal.hygiene.deferred"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "idempotency_store",
      "app": "storage_by_zapier",
      "event": "set_value",
      "key_template": "deal-hygiene:${event_id}",
      "value_fields": [
        "event_id",
        "approval_status",
        "trace.trace_id",
        "trace.run_id"
      ]
    }
  ],
  "zapier_runtime_profile": {
    "paths": {
      "max_branches_per_group": 10,
      "max_nested_paths_steps": 3,
      "max_total_steps": 100,
      "must_be_final_step": true,
      "no_shared_post_path_actions": true
    },
    "filters": {
      "consume_tasks": false
    },
    "code": {
      "javascript_runtime": "nodejs_22",
      "io_limit_mb": 6,
      "plan_limits": {
        "free": {
          "runtime_seconds": 1,
          "requests": "10_per_60s"
        },
        "trial": {
          "runtime_seconds": 10,
          "requests": "75_per_10s"
        },
        "professional_team": {
          "runtime_seconds": 30,
          "requests": "225_per_10s"
        },
        "enterprise": {
          "runtime_seconds": 120,
          "requests": "225_per_10s"
        }
      }
    }
  }
}
