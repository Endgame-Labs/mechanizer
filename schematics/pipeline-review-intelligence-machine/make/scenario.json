{
  "name": "pipeline-review-intelligence-machine-v2",
  "machine_id": "pipeline-review-intelligence-machine",
  "artifact_type": "make_scenario_blueprint_reference",
  "make_runtime": {
    "scheduling": {
      "mode": "instant_webhook_plus_periodic_refresh",
      "webhook_path": "pipeline-review-events",
      "periodic_refresh_interval_minutes": 30,
      "max_runs_per_minute": 30,
      "sequential_processing": true
    }
  },
  "modules": [
    {
      "id": 1,
      "module": "webhooks:customWebhook",
      "name": "Receive Pipeline Event",
      "parameters": {
        "path": "pipeline-review-events"
      }
    },
    {
      "id": 2,
      "module": "json:createJSON",
      "name": "Normalize gtm_event_v1"
    },
    {
      "id": 3,
      "module": "datastore:getARecord",
      "name": "Idempotency Lookup",
      "parameters": {
        "store": "pipeline_review_runs",
        "key": "pipeline-review:{{2.event_id}}"
      }
    },
    {
      "id": 4,
      "module": "flow:filter",
      "name": "Skip Duplicates",
      "filter": "{{empty(3.value)}}"
    },
    {
      "id": 5,
      "module": "http:makeRequest",
      "name": "Fetch Context",
      "parameters": {
        "url": "https://context.internal/pipeline-review/enrich",
        "method": "POST",
        "body": "{{toJSON(2)}}"
      }
    },
    {
      "id": 6,
      "module": "http:makeRequest",
      "name": "Score Deals",
      "parameters": {
        "url": "https://cogs.internal/deal_score_reasoner/v1/execute",
        "method": "POST",
        "body": "{{5.body}}"
      }
    },
    {
      "id": 7,
      "module": "tools:iterator",
      "name": "Iterate Findings",
      "parameters": {
        "array": "{{6.body.findings}}"
      }
    },
    {
      "id": 8,
      "module": "tools:arrayAggregator",
      "name": "Aggregate Review Packet",
      "parameters": {
        "source": "7",
        "target_structure": "findings[]"
      }
    },
    {
      "id": 9,
      "module": "http:makeRequest",
      "name": "Approval Loop",
      "parameters": {
        "url": "https://approval.internal/request",
        "method": "POST",
        "body": "{\"event_id\":\"{{2.event_id}}\",\"review_packet\":{{8.array}},\"timeout_seconds\":1800}"
      }
    },
    {
      "id": 10,
      "module": "flow:router",
      "name": "Approval Router",
      "routes": [
        {
          "name": "approved",
          "condition": "{{9.body.approval_status}} = approved"
        },
        {
          "name": "blocked",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 11,
      "module": "slack:createAMessage",
      "name": "Post Review Digest",
      "route": "approved"
    },
    {
      "id": 12,
      "module": "salesforce:updateARecord",
      "name": "Writeback Forecast Fields",
      "route": "approved",
      "parameters": {
        "object": "Opportunity",
        "record_id": "{{2.subject.id}}"
      }
    },
    {
      "id": 13,
      "module": "http:makeRequest",
      "name": "Emit Outcome Event",
      "parameters": {
        "url": "https://events.internal/emit",
        "method": "POST",
        "body": "{\"event_type\":\"{{if(10.route = \\\"approved\\\"; \\\"pipeline.review.prep.completed\\\"; \\\"pipeline.review.prep.deferred\\\")}}\",\"event_id\":\"{{2.event_id}}\"}"
      }
    }
  ]
}
