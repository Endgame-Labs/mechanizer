{
  "zap_name": "Sales Coaching - Call Completed",
  "version": "1.2.0",
  "machine_id": "sales-coaching-machine",
  "description": "Processes call-completed events to generate directive-aligned coaching actions with approval-gated CRM writes.",
  "trigger": {
    "app": "webhooks_by_zapier",
    "event": "catch_hook",
    "path": "/sales-coaching/call-completed",
    "accepted_sources": [
      "gong",
      "zoom",
      "chorus"
    ]
  },
  "gtm_event_v1_mapping": {
    "required": [
      "schema_version",
      "event_id",
      "event_type",
      "source",
      "occurred_at",
      "ingested_at",
      "trace",
      "subject",
      "attributes"
    ]
  },
  "steps": [
    {
      "id": "filter_call_completed",
      "app": "filter_by_zapier",
      "event": "only_continue_if",
      "conditions": [
        {
          "field": "event_type",
          "operator": "equals",
          "value": "call.completed"
        },
        {
          "field": "attributes.opportunity_id",
          "operator": "exists"
        }
      ]
    },
    {
      "id": "normalize_gtm_event",
      "app": "code_by_zapier",
      "event": "run_javascript"
    },
    {
      "id": "idempotency_lookup",
      "app": "storage_by_zapier",
      "event": "get_value",
      "key_template": "sales-coaching:${event_id}"
    },
    {
      "id": "fetch_context",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://context.internal/sales-coaching/enrich",
        "json": {
          "event": "{{steps.normalize_gtm_event.output}}",
          "context_providers": [
            "endgame_mcp_or_cli",
            "salesforce_headless_360",
            "enablement_provider",
            "call_intelligence_provider"
          ]
        }
      }
    },
    {
      "id": "directive_alignment",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://cogs.internal/directive_alignment/v1/execute"
      }
    },
    {
      "id": "approval_loop",
      "app": "human_in_the_loop",
      "event": "request_approval",
      "fallback": {
        "app": "webhooks_by_zapier",
        "event": "post",
        "url": "https://approval.internal/request"
      },
      "request_payload": {
        "event_id": "{{event_id}}",
        "opportunity_id": "{{attributes.opportunity_id}}",
        "alignment_score": "{{steps.directive_alignment.body.score}}",
        "proposed_actions": [
          "create_salesforce_task"
        ]
      }
    },
    {
      "id": "alignment_paths",
      "app": "paths_by_zapier",
      "event": "branch",
      "paths": [
        {
          "name": "approved_and_aligned",
          "conditions": [
            {
              "field": "{{steps.directive_alignment.body.status}}",
              "operator": "equals",
              "value": "pass"
            },
            {
              "field": "{{steps.approval_loop.approval_status}}",
              "operator": "equals",
              "value": "approved"
            }
          ],
          "actions": [
            {
              "id": "create_salesforce_task",
              "app": "salesforce",
              "event": "create_record",
              "object": "Task",
              "idempotency_key": "{{event_id}}"
            },
            {
              "id": "emit_approved_event",
              "app": "webhooks_by_zapier",
              "event": "post",
              "request": {
                "url": "https://events.internal/emit",
                "json": {
                  "event_type": "coaching.recommendation.created"
                }
              }
            }
          ]
        },
        {
          "name": "blocked",
          "conditions": [
            {
              "field": "{{steps.approval_loop.approval_status}}",
              "operator": "does_not_equal",
              "value": "approved"
            }
          ],
          "actions": [
            {
              "id": "notify_manager",
              "app": "slack",
              "event": "send_channel_message"
            },
            {
              "id": "emit_blocked_event",
              "app": "webhooks_by_zapier",
              "event": "post",
              "request": {
                "url": "https://events.internal/emit",
                "json": {
                  "event_type": "coaching.recommendation.blocked"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "idempotency_store",
      "app": "storage_by_zapier",
      "event": "set_value",
      "key_template": "sales-coaching:${event_id}",
      "value_fields": [
        "event_id",
        "approval_status",
        "alignment_status",
        "trace.trace_id",
        "trace.run_id"
      ]
    }
  ],
  "zapier_runtime_profile": {
    "paths": {
      "max_branches_per_group": 10,
      "max_nested_paths_steps": 3,
      "max_total_steps": 100,
      "must_be_final_step": true
    },
    "webhooks": {
      "raw_hook_max_mb": 2,
      "payload_limit_mb": {
        "triggers": 10,
        "actions": 5
      }
    },
    "replay": {
      "manual_replay_available": true,
      "autoreplay_available_on": [
        "professional",
        "team",
        "enterprise"
      ],
      "human_in_the_loop_may_not_autoreplay_in_some_configurations": true
    }
  }
}
