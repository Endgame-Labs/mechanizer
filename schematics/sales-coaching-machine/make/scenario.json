{
  "name": "sales-coaching-machine-call-complete-v3",
  "machine_id": "sales-coaching-machine",
  "artifact_type": "make_scenario_blueprint_reference",
  "make_runtime": {
    "scheduling": {
      "mode": "instant_webhook",
      "max_runs_per_minute": 40,
      "sequential_processing": true
    },
    "retry_model": {
      "store_incomplete_executions": true,
      "auto_retry_errors": [
        "RateLimitError",
        "ConnectionError",
        "ModuleTimeoutError"
      ]
    }
  },
  "modules": [
    {
      "id": 1,
      "module": "webhooks:customWebhook",
      "name": "Call Completed Webhook",
      "parameters": {
        "name": "sales-coaching-call-completed"
      }
    },
    {
      "id": 2,
      "module": "json:createJSON",
      "name": "Normalize gtm_event_v1"
    },
    {
      "id": 3,
      "module": "http:makeRequest",
      "name": "Fetch Context",
      "parameters": {
        "url": "https://context.internal/sales-coaching/enrich",
        "method": "POST",
        "body": "{{toJSON(2)}}"
      }
    },
    {
      "id": 4,
      "module": "http:makeRequest",
      "name": "Directive Alignment",
      "parameters": {
        "url": "https://cogs.internal/directive_alignment/v1/execute",
        "method": "POST",
        "body": "{{3.body}}"
      }
    },
    {
      "id": 5,
      "module": "flow:router",
      "name": "Recommendation Router",
      "routes": [
        {
          "name": "coaching_task",
          "condition": "{{4.body.status}} = pass AND {{4.body.score}} >= 0.85"
        },
        {
          "name": "escalate",
          "condition": "{{4.body.status}} = pass AND {{4.body.score}} < 0.85"
        },
        {
          "name": "blocked",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 6,
      "module": "http:makeRequest",
      "name": "Approval Loop",
      "parameters": {
        "url": "https://approval.internal/request",
        "method": "POST",
        "body": "{\"event_id\":\"{{2.event_id}}\",\"subject\":{{2.subject}},\"recommendation\":{{4.body.recommendation}},\"timeout_seconds\":1800}"
      }
    },
    {
      "id": 7,
      "module": "flow:router",
      "name": "Approval Router",
      "routes": [
        {
          "name": "approved",
          "condition": "{{6.body.approval_status}} = approved"
        },
        {
          "name": "blocked",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 8,
      "module": "salesforce:createARecord",
      "name": "Create Coaching Task",
      "route": "approved",
      "parameters": {
        "object": "Task"
      }
    },
    {
      "id": 9,
      "module": "slack:createAMessage",
      "name": "Escalation Message",
      "route": "approved",
      "parameters": {
        "channel": "#revops-escalations"
      }
    },
    {
      "id": 10,
      "module": "http:makeRequest",
      "name": "Emit Outcome",
      "parameters": {
        "url": "https://events.internal/emit",
        "method": "POST",
        "body": "{\"event_type\":\"{{if(7.route = \\\"approved\\\"; \\\"coaching.recommendation.created\\\"; \\\"coaching.recommendation.blocked\\\")}}\",\"event_id\":\"{{2.event_id}}\"}"
      }
    }
  ],
  "error_handlers": [
    {
      "on": [
        "http:makeRequest",
        "salesforce:createARecord",
        "slack:createAMessage"
      ],
      "strategy": "break_with_incomplete_execution_retry",
      "dead_letter_url": "https://events.internal/dead-letter"
    }
  ]
}
