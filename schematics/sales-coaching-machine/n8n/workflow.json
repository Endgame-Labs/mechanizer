      "error_workflow": "Attach Error Trigger workflow in Workflow Settings",
      "queue_mode_ready": true
    }
  },
  "nodes": [
    {
      "parameters": {
        "path": "sales-coaching/call-completed",
        "httpMethod": "POST",
        "responseMode": "responseNode"
      },
      "id": "webhook_call_completed",
      "name": "Webhook - Call Completed",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 280]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.headers['x-gong-signature'] || ''}}",
              "operation": "notEmpty"
            },
            {
              "value1": "={{$json.body.type || ''}}",
              "operation": "equal",
              "value2": "call.completed"
            }
          ]
        }
      },
      "id": "verify_signature",
      "name": "Verify Signature + Event Type",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [430, 280]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const b = $json.body;\nif (!b?.id) throw new Error('Missing body.id');\nif (!b?.call?.id) throw new Error('Missing call.id');\nreturn {\n  event_id: b.id,\n  event_type: b.type,\n  source: 'gong',\n  occurred_at: b.call.occurred_at,\n  ingested_at: new Date().toISOString(),\n  trace: { trace_id: `trace_${b.id}`, run_id: `${b.id}:${Date.now()}` },\n  subject: { entity_type: 'call', entity_id: b.call.id },\n  attributes: {\n    account_id: b.call.account_id,\n    opportunity_id: b.call.opportunity_id,\n    rep_email: b.call.rep_email,\n    transcript_id: b.call.transcript_id || null,\n    directive_set_version: 'sko_2026_q2_v3'\n  }\n};"
      },
      "id": "normalize_event",
      "name": "Normalize to gtm_event_v1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [670, 280]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://cogs.internal/enrich_account_health/v1/execute",
        "sendBody": true,
        "jsonBody": "={{$json}}"
      },
      "id": "enrich_account_health",
      "name": "enrich_account_health",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [910, 180],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
