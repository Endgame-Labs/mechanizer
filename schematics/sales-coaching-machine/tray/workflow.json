{
  "name": "sales-coaching-machine-call-complete",
  "machine_id": "sales-coaching-machine",
  "version": "1.2.0",
  "trigger": {
    "type": "callable",
    "operation": "trigger_and_respond",
    "name": "sales_coaching_ingest",
    "input_schema": "gtm_event_v1",
    "accepts_event_types": [
      "call.completed"
    ]
  },
  "contract": {
    "idempotency_key": "event_id",
    "approval_required_for_side_effects": true
  },
  "steps": [
    {
      "id": "normalize_validate",
      "type": "script",
      "language": "javascript",
      "notes": "Validate call.completed payload and normalize trace/subject/attributes."
    },
    {
      "id": "idempotency_get",
      "type": "data_storage.get_value",
      "input": {
        "scope": "project",
        "key": "sales-coaching:${steps.normalize_validate.output.event_id}",
        "default": null
      }
    },
    {
      "id": "branch_if_new",
      "type": "branch",
      "branches": [
        {
          "name": "new",
          "when": "steps.idempotency_get.output == null"
        },
        {
          "name": "duplicate",
          "when": "steps.idempotency_get.output != null"
        }
      ]
    },
    {
      "id": "context_enrichment_cog",
      "branch": "new",
      "type": "call_workflow",
      "operation": "fire_and_wait_for_response",
      "workflow": "shared_context_enrichment",
      "input": {
        "event": "${steps.normalize_validate.output}",
        "providers": [
          "endgame_mcp",
          "salesforce_headless_360",
          "gong_or_zoom"
        ]
      }
    },
    {
      "id": "coaching_recommendation_cog",
      "branch": "new",
      "type": "call_workflow",
      "operation": "fire_and_wait_for_response",
      "workflow": "shared_coaching_recommendation",
      "input": {
        "event": "${steps.normalize_validate.output}",
        "context": "${steps.context_enrichment_cog.output}"
      }
    },
    {
      "id": "directive_alignment_cog",
      "branch": "new",
      "type": "call_workflow",
      "operation": "fire_and_wait_for_response",
      "workflow": "shared_directive_alignment",
      "input": {
        "recommendation": "${steps.coaching_recommendation_cog.output}",
        "context": "${steps.context_enrichment_cog.output}"
      }
    },
    {
      "id": "alignment_branch",
      "branch": "new",
      "type": "branch",
      "branches": [
        {
          "name": "high_confidence",
          "when": "steps.directive_alignment_cog.output.score >= 0.85"
        },
        {
          "name": "low_confidence",
          "when": "steps.directive_alignment_cog.output.score < 0.85"
        }
      ]
    },
    {
      "id": "approval_loop_cog",
      "branch": "high_confidence",
      "type": "call_workflow",
      "operation": "fire_and_wait_for_response",
      "workflow": "shared_approval_loop",
      "input": {
        "machine_id": "sales-coaching-machine",
        "event_id": "${steps.normalize_validate.output.event_id}",
        "actions": [
          "salesforce.create_record",
          "slack.post_message"
        ],
        "proposal": "${steps.coaching_recommendation_cog.output}",
        "timeout_seconds": 1200
      }
    },
    {
      "id": "approved_branch",
      "branch": "high_confidence",
      "type": "branch",
      "branches": [
        {
          "name": "approved",
          "when": "steps.approval_loop_cog.output.approval_status == 'approved'"
        },
        {
          "name": "blocked",
          "when": "steps.approval_loop_cog.output.approval_status != 'approved'"
        }
      ]
    },
    {
      "id": "create_salesforce_task",
      "branch": "approved",
      "type": "salesforce.create_record",
      "error_handling": "manual",
      "input": {
        "object": "Task",
        "fields": {
          "Subject": "Coaching recommendation from completed call",
          "Description": "${steps.coaching_recommendation_cog.output.summary}",
          "WhatId": "${steps.normalize_validate.output.attributes.opportunity_id}"
        }
      }
    },
    {
      "id": "notify_manager_slack",
      "branch": "approved",
      "type": "slack.post_message",
      "error_handling": "manual",
      "input": {
        "channel": "#sales-coaching",
        "text": "${steps.coaching_recommendation_cog.output.summary}"
      }
    },
    {
      "id": "escalate_alignment_gap",
      "branch": "low_confidence",
      "type": "slack.post_message",
      "input": {
        "channel": "#revops-escalations",
        "text": "Low-confidence coaching recommendation for call ${steps.normalize_validate.output.subject.id}."
      }
    },
    {
      "id": "emit_output",
      "branch": "new",
      "type": "http.client",
      "input": {
        "method": "POST",
        "url": "https://event-bus.example/v1/events",
        "body": {
          "schema_version": "gtm_event_v1",
          "event_type": "coaching.recommendation.created",
          "source": "tray",
          "trace": "${steps.normalize_validate.output.trace}",
          "subject": "${steps.normalize_validate.output.subject}",
          "attributes": {
            "alignment_score": "${steps.directive_alignment_cog.output.score}",
            "approval_status": "${steps.approval_loop_cog.output.approval_status || 'not_required'}"
          }
        }
      }
    },
    {
      "id": "idempotency_set",
      "branch": "new",
      "type": "data_storage.set_value",
      "input": {
        "scope": "project",
        "key": "sales-coaching:${steps.normalize_validate.output.event_id}",
        "value": {
          "status": "completed",
          "updated_at": "${meta.now}"
        }
      }
    },
    {
      "id": "response_duplicate",
      "branch": "duplicate",
      "type": "callable_workflow_response",
      "body": {
        "event_type": "coaching.recommendation.duplicate_ignored",
        "status": "ignored"
      }
    },
    {
      "id": "response_new",
      "branch": "new",
      "type": "callable_workflow_response",
      "body": {
        "event_type": "coaching.recommendation.created",
        "trace": "${steps.normalize_validate.output.trace}",
        "attributes": {
          "alignment_score": "${steps.directive_alignment_cog.output.score}",
          "approval_status": "${steps.approval_loop_cog.output.approval_status || 'not_required'}"
        }
      }
    }
  ],
  "error_handler": {
    "mode": "automatic_default_with_manual_overrides",
    "manual_paths_for": [
      "create_salesforce_task",
      "notify_manager_slack"
    ],
    "dead_letter": {
      "workflow": "shared_dead_letter_handler",
      "required_fields": [
        "machine_id",
        "event_id",
        "trace_id",
        "step_name",
        "step_log_url",
        "error"
      ]
    }
  }
}
