{
  "name": "stage-change-deal-review-machine-v2",
  "machine_id": "stage-change-deal-review-machine",
  "artifact_type": "make_scenario_blueprint_reference",
  "make_runtime": {
    "scheduling": {
      "mode": "webhook_plus_periodic_sweep",
      "webhook_path": "stage-change-deal-review-events",
      "periodic_sweep_interval_minutes": 15,
      "max_runs_per_minute": 35,
      "sequential_processing": true
    },
    "retry_model": {
      "store_incomplete_executions": true,
      "auto_retry_errors": [
        "RateLimitError",
        "ConnectionError",
        "ModuleTimeoutError"
      ]
    }
  },
  "modules": [
    {
      "id": 1,
      "module": "webhooks:customWebhook",
      "name": "Receive Stage-Change Event",
      "parameters": {
        "path": "stage-change-deal-review-events"
      }
    },
    {
      "id": 2,
      "module": "json:createJSON",
      "name": "Normalize gtm_event_v1"
    },
    {
      "id": 3,
      "module": "datastore:getARecord",
      "name": "Idempotency Lookup",
      "parameters": {
        "store": "stage_change_review_runs",
        "key": "stage-change-review:{{2.event_id}}"
      }
    },
    {
      "id": 4,
      "module": "flow:filter",
      "name": "Skip Duplicates",
      "filter": "{{empty(3.value)}}"
    },
    {
      "id": 5,
      "module": "http:makeRequest",
      "name": "Fetch Context",
      "parameters": {
        "url": "https://context.internal/stage-change-review/enrich",
        "method": "POST",
        "body": "{{toJSON(2)}}"
      }
    },
    {
      "id": 6,
      "module": "http:makeRequest",
      "name": "Score Stage-Change Risk",
      "parameters": {
        "url": "https://cogs.internal/deal_score_reasoner/v1/execute",
        "method": "POST",
        "body": "{{5.body}}"
      }
    },
    {
      "id": 7,
      "module": "flow:router",
      "name": "Severity Router",
      "routes": [
        {
          "name": "writeback_candidate",
          "condition": "{{6.body.score}} >= 70"
        },
        {
          "name": "findings_only",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 8,
      "module": "http:makeRequest",
      "name": "Approval Loop",
      "parameters": {
        "url": "https://approval.internal/request",
        "method": "POST",
        "body": "{\"event_id\":\"{{2.event_id}}\",\"subject\":{{2.subject}},\"proposed_updates\":{{6.body.proposed_mutations}},\"timeout_seconds\":1800}"
      }
    },
    {
      "id": 9,
      "module": "flow:router",
      "name": "Approval Router",
      "routes": [
        {
          "name": "approved",
          "condition": "{{8.body.approval_status}} = approved"
        },
        {
          "name": "deferred",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 10,
      "module": "salesforce:updateARecord",
      "name": "Apply Salesforce Writeback",
      "route": "approved",
      "parameters": {
        "object": "Opportunity",
        "record_id": "{{2.subject.id}}"
      }
    },
    {
      "id": 11,
      "module": "slack:createAMessage",
      "name": "Post Findings",
      "route": "deferred",
      "parameters": {
        "channel": "#pipeline-findings"
      }
    },
    {
      "id": 12,
      "module": "http:makeRequest",
      "name": "Emit Outcome Event",
      "parameters": {
        "url": "https://events.internal/emit",
        "method": "POST",
        "body": "{\"event_type\":\"{{if(9.route = \\\"approved\\\"; \\\"deal.stage_review.writeback_applied\\\"; \\\"deal.stage_review.findings_posted\\\")}}\",\"event_id\":\"{{2.event_id}}\"}"
      }
    }
  ]
}
