{
  "zap_name": "Stage Change Deal Review Machine",
  "version": "1.1.0",
  "machine_id": "stage-change-deal-review-machine",
  "description": "Reviews stage progression risk and applies approval-gated CRM updates.",
  "trigger": {
    "primary": {
      "app": "webhooks_by_zapier",
      "event": "catch_hook",
      "path": "/stage-change-deal-review/events"
    },
    "alternate": {
      "app": "salesforce",
      "event": "updated_record",
      "object": "Opportunity"
    },
    "accepts_event_types": [
      "deal.stage_changed",
      "opportunity.stage_changed"
    ]
  },
  "steps": [
    {
      "id": "normalize_validate",
      "app": "code_by_zapier",
      "event": "run_javascript"
    },
    {
      "id": "idempotency_lookup",
      "app": "storage_by_zapier",
      "event": "get_value",
      "key_template": "stage-change-deal-review:${event_id}"
    },
    {
      "id": "enrich_account_health",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://cogs.internal/enrich_account_health/v1/execute"
      }
    },
    {
      "id": "deal_score_reasoner",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://cogs.internal/deal_score_reasoner/v1/execute"
      }
    },
    {
      "id": "directive_alignment",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://cogs.internal/directive_alignment/v1/execute"
      }
    },
    {
      "id": "approval_loop",
      "app": "human_in_the_loop",
      "event": "request_approval",
      "fallback": {
        "app": "webhooks_by_zapier",
        "event": "post",
        "url": "https://approval.internal/request"
      }
    },
    {
      "id": "path_on_approval",
      "app": "paths_by_zapier",
      "event": "branch",
      "paths": [
        {
          "name": "approved",
          "condition": "approval_status == 'approved'",
          "actions": [
            {
              "id": "sfdc_writeback",
              "app": "salesforce",
              "event": "update_record",
              "object": "Opportunity",
              "idempotency_key": "{{event_id}}"
            },
            {
              "id": "emit_writeback_applied",
              "app": "webhooks_by_zapier",
              "event": "post",
              "request": {
                "url": "https://events.internal/publish",
                "json": {
                  "event_type": "deal.stage_review.writeback_applied"
                }
              }
            }
          ]
        },
        {
          "name": "findings",
          "condition": "approval_status != 'approved'",
          "actions": [
            {
              "id": "post_slack_findings",
              "app": "slack",
              "event": "send_channel_message"
            },
            {
              "id": "emit_findings_posted",
              "app": "webhooks_by_zapier",
              "event": "post",
              "request": {
                "url": "https://events.internal/publish",
                "json": {
                  "event_type": "deal.stage_review.findings_posted"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
