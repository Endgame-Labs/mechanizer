{
  "name": "meeting-prep-brief-machine-v2",
  "machine_id": "meeting-prep-brief-machine",
  "artifact_type": "make_scenario_blueprint_reference",
  "make_runtime": {
    "scheduling": {
      "mode": "webhook_plus_periodic_sweep",
      "webhook_path": "meeting-prep-events",
      "periodic_sweep_interval_minutes": 15,
      "sequential_processing": true,
      "max_runs_per_minute": 35
    }
  },
  "modules": [
    {
      "id": 1,
      "module": "webhooks:customWebhook",
      "name": "Receive Meeting Event",
      "parameters": {
        "path": "meeting-prep-events"
      }
    },
    {
      "id": 2,
      "module": "json:createJSON",
      "name": "Normalize gtm_event_v1"
    },
    {
      "id": 3,
      "module": "datastore:getARecord",
      "name": "Idempotency Lookup",
      "parameters": {
        "store": "meeting_prep_runs",
        "key": "meeting-prep:{{2.event_id}}"
      }
    },
    {
      "id": 4,
      "module": "flow:filter",
      "name": "Skip Duplicates",
      "filter": "{{empty(3.value)}}"
    },
    {
      "id": 5,
      "module": "http:makeRequest",
      "name": "Fetch Context",
      "parameters": {
        "url": "https://context.internal/meeting-prep/enrich",
        "method": "POST",
        "body": "{{toJSON(2)}}"
      }
    },
    {
      "id": 6,
      "module": "http:makeRequest",
      "name": "Score Priority",
      "parameters": {
        "url": "https://cogs.internal/deal_score_reasoner/v1/execute",
        "method": "POST",
        "body": "{{5.body}}"
      }
    },
    {
      "id": 7,
      "module": "flow:router",
      "name": "Prep Depth Router",
      "routes": [
        {
          "name": "deep_brief",
          "condition": "{{6.body.score}} >= 75"
        },
        {
          "name": "standard_brief",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 8,
      "module": "tools:iterator",
      "name": "Iterate Brief Sections",
      "parameters": {
        "array": "{{5.body.brief_sections}}"
      }
    },
    {
      "id": 9,
      "module": "tools:arrayAggregator",
      "name": "Aggregate Brief",
      "parameters": {
        "source": "8",
        "target_structure": "brief_sections[]"
      }
    },
    {
      "id": 10,
      "module": "http:makeRequest",
      "name": "Approval Loop",
      "parameters": {
        "url": "https://approval.internal/request",
        "method": "POST",
        "body": "{\"event_id\":\"{{2.event_id}}\",\"brief\":{{9.array}},\"timeout_seconds\":1200}"
      }
    },
    {
      "id": 11,
      "module": "flow:router",
      "name": "Approval Router",
      "routes": [
        {
          "name": "approved",
          "condition": "{{10.body.approval_status}} = approved"
        },
        {
          "name": "blocked",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 12,
      "module": "slack:createAMessage",
      "name": "Deliver Slack Brief",
      "route": "approved"
    },
    {
      "id": 13,
      "module": "gmail:sendAnEmail",
      "name": "Deliver Email Brief",
      "route": "approved"
    },
    {
      "id": 14,
      "module": "http:makeRequest",
      "name": "Emit Outcome Event",
      "parameters": {
        "url": "https://events.internal/emit",
        "method": "POST",
        "body": "{\"event_type\":\"{{if(11.route = \\\"approved\\\"; \\\"meeting.prep_brief.delivered\\\"; \\\"meeting.prep_brief.blocked\\\")}}\",\"event_id\":\"{{2.event_id}}\"}"
      }
    },
    {
      "id": 15,
      "module": "datastore:addOrReplaceARecord",
      "name": "Write Run Summary",
      "parameters": {
        "store": "meeting_prep_runs",
        "key": "meeting-prep:{{2.event_id}}"
      }
    }
  ]
}
