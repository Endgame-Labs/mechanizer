{
  "zap_name": "Long Tail Account Coverage Machine",
  "version": "1.1.0",
  "machine_id": "long-tail-account-coverage-machine",
  "description": "Monitors long-tail accounts and executes approval-gated outreach plays.",
  "trigger": {
    "primary": {
      "app": "webhooks_by_zapier",
      "event": "catch_hook",
      "path": "/longtail-account-coverage/events"
    },
    "alternate": {
      "app": "schedule_by_zapier",
      "event": "every_6_hours"
    }
  },
  "steps": [
    {
      "id": "validate_contract",
      "app": "code_by_zapier",
      "event": "run_javascript"
    },
    {
      "id": "filter_supported_events",
      "app": "filter_by_zapier",
      "event": "only_continue_if",
      "rule": "event_type in ['account.health_changed','usage.declined','renewal.window_opened','intent.signal_detected']"
    },
    {
      "id": "idempotency_lookup",
      "app": "storage_by_zapier",
      "event": "get_value",
      "key_template": "longtail-coverage:${event_id}"
    },
    {
      "id": "fetch_context",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://context.internal/enrich",
        "json": {
          "providers": [
            "endgame_mcp_or_cli",
            "salesforce_headless_360",
            "product_telemetry",
            "support_system"
          ]
        }
      }
    },
    {
      "id": "segment_filter",
      "app": "filter_by_zapier",
      "event": "only_continue_if",
      "rule": "segment in ['low_touch','no_touch']"
    },
    {
      "id": "score_account",
      "app": "code_by_zapier",
      "event": "run_javascript"
    },
    {
      "id": "compose_outreach",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://planner.internal/compose"
      }
    },
    {
      "id": "approval_loop",
      "app": "human_in_the_loop",
      "event": "request_approval",
      "fallback": {
        "app": "webhooks_by_zapier",
        "event": "post",
        "url": "https://approval.internal/request"
      }
    },
    {
      "id": "approval_paths",
      "app": "paths_by_zapier",
      "event": "branch",
      "paths": [
        {
          "name": "approved",
          "condition": "approval_status == 'approved'",
          "actions": [
            {
              "id": "send_email",
              "app": "gmail",
              "event": "send_email"
            },
            {
              "id": "update_crm",
              "app": "salesforce",
              "event": "create_note"
            },
            {
              "id": "emit_executed",
              "app": "webhooks_by_zapier",
              "event": "post",
              "request": {
                "url": "https://events.internal/emit",
                "json": {
                  "event_type": "longtail.coverage.executed"
                }
              }
            }
          ]
        },
        {
          "name": "blocked",
          "condition": "approval_status != 'approved'",
          "actions": [
            {
              "id": "emit_blocked",
              "app": "webhooks_by_zapier",
              "event": "post",
              "request": {
                "url": "https://events.internal/emit",
                "json": {
                  "event_type": "longtail.coverage.blocked"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
