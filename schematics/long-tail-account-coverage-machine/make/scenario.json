{
  "name": "long-tail-account-coverage-machine-v1",
  "machine_id": "long-tail-account-coverage-machine",
  "artifact_type": "make_scenario_blueprint_reference",
  "make_runtime": {
    "scheduling": {
      "mode": "webhook_plus_periodic_rescore",
      "webhook_path": "longtail-coverage-events",
      "periodic_rescore_interval_hours": 6,
      "max_runs_per_minute": 25,
      "sequential_processing": true
    }
  },
  "modules": [
    {
      "id": 1,
      "module": "webhooks:customWebhook",
      "name": "Receive Long Tail Event",
      "parameters": {
        "path": "longtail-coverage-events"
      }
    },
    {
      "id": 2,
      "module": "json:createJSON",
      "name": "Normalize gtm_event_v1"
    },
    {
      "id": 3,
      "module": "http:makeRequest",
      "name": "Enrich Context",
      "parameters": {
        "url": "https://context.internal/longtail/enrich",
        "method": "POST",
        "body": "{{toJSON(2)}}"
      }
    },
    {
      "id": 4,
      "module": "http:makeRequest",
      "name": "Score Account",
      "parameters": {
        "url": "https://cogs.internal/deal_score_reasoner/v1/execute",
        "method": "POST",
        "body": "{{3.body}}"
      }
    },
    {
      "id": 5,
      "module": "flow:router",
      "name": "Risk Router",
      "routes": [
        {
          "name": "high_risk",
          "condition": "{{4.body.score}} >= 78"
        },
        {
          "name": "expansion",
          "condition": "{{4.body.score}} >= 70 AND {{4.body.health_risk}} < 60"
        },
        {
          "name": "monitor",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 6,
      "module": "http:makeRequest",
      "name": "Approval Loop",
      "parameters": {
        "url": "https://approval.internal/request",
        "method": "POST",
        "body": "{\"event_id\":\"{{2.event_id}}\",\"subject\":{{2.subject}},\"proposed_actions\":{{4.body.recommended_actions}},\"timeout_seconds\":1800}"
      }
    },
    {
      "id": 7,
      "module": "flow:router",
      "name": "Approval Router",
      "routes": [
        {
          "name": "approved",
          "condition": "{{6.body.approval_status}} = approved"
        },
        {
          "name": "blocked",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 8,
      "module": "gmail:sendAnEmail",
      "name": "Send Outreach",
      "route": "approved"
    },
    {
      "id": 9,
      "module": "salesforce:updateARecord",
      "name": "Update CRM",
      "route": "approved",
      "parameters": {
        "object": "Account",
        "record_id": "{{2.subject.id}}"
      }
    },
    {
      "id": 10,
      "module": "http:makeRequest",
      "name": "Emit Outcome Event",
      "parameters": {
        "url": "https://events.internal/emit",
        "method": "POST",
        "body": "{\"event_type\":\"{{if(7.route = \\\"approved\\\"; \\\"longtail.coverage.executed\\\"; \\\"longtail.coverage.blocked\\\")}}\",\"event_id\":\"{{2.event_id}}\"}"
      }
    }
  ]
}
