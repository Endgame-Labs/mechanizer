{
  "zap_name": "NRR Machine - Low/No Touch",
  "version": "1.1.0",
  "machine_id": "nrr-machine",
  "description": "Processes canonical gtm_event_v1 health/renewal events, scores account risk/opportunity, requests approval, then executes outbound and Salesforce updates when approved.",
  "trigger": {
    "app": "webhooks_by_zapier",
    "event": "catch_hook",
    "path": "/nrr/events"
  },
  "gtm_event_v1_mapping": {
    "required": [
      "schema_version",
      "event_id",
      "event_type",
      "source",
      "occurred_at",
      "ingested_at",
      "trace",
      "subject",
      "attributes"
    ]
  },
  "steps": [
    {
      "id": "validate_contract",
      "type": "code",
      "runtime": "javascript",
      "input_fields": [
        "schema_version",
        "event_id",
        "event_type",
        "source",
        "occurred_at",
        "ingested_at",
        "trace",
        "subject",
        "attributes"
      ],
      "output_fields": [
        "event_valid",
        "validation_error"
      ]
    },
    {
      "id": "filter_supported_events",
      "type": "filter",
      "rule": "event_type in ['account.health_changed','usage.declined','renewal.window_opened']"
    },
    {
      "id": "fetch_context",
      "type": "webhook_post",
      "url": "https://context.internal/enrich",
      "payload": {
        "providers": [
          "salesforce_headless_360",
          "telemetry",
          "billing",
          "endgame_mcp"
        ],
        "event": "{{trigger.raw_body}}"
      }
    },
    {
      "id": "segment_filter",
      "type": "filter",
      "rule": "segment in ['low_touch','no_touch']"
    },
    {
      "id": "score_account",
      "type": "code",
      "runtime": "javascript",
      "logic": "score=Math.round((0.45*health_risk)+(0.35*renewal_risk)+(0.20*expansion_signal)); if(score>=78){play='critical_retention';} else if(score>=72 && health_risk<60){play='expansion_push';} else {play='monitor_and_nudge';}"
    },
    {
      "id": "compose_action_plan",
      "type": "webhook_post",
      "url": "https://planner.internal/compose",
      "payload": {
        "account_id": "{{subject.id}}",
        "score": "{{steps.score_account.score}}",
        "play": "{{steps.score_account.play}}"
      }
    },
    {
      "id": "approval_loop",
      "type": "webhook_post",
      "url": "https://approval.internal/request",
      "payload": {
        "event_id": "{{event_id}}",
        "account_id": "{{subject.id}}",
        "score": "{{steps.score_account.score}}",
        "play": "{{steps.score_account.play}}",
        "actions": [
          "outbound_email_send",
          "renewal_plan_update"
        ],
        "timeout_seconds": 1800
      }
    },
    {
      "id": "path_on_approval",
      "type": "paths",
      "branches": [
        {
          "name": "approved",
          "condition": "approval_status == 'approved'",
          "actions": [
            {
              "id": "send_outbound",
              "app": "gmail",
              "event": "send_email"
            },
            {
              "id": "update_salesforce",
              "app": "salesforce",
              "event": "update_record",
              "object": "Account",
              "idempotency_key": "{{event_id}}"
            },
            {
              "id": "emit_executed_event",
              "type": "webhook_post",
              "url": "https://events.internal/emit",
              "payload": {
                "event_type": "nrr.play.executed",
                "event_id": "{{event_id}}",
                "score": "{{steps.score_account.score}}",
                "play": "{{steps.score_account.play}}"
              }
            },
            {
              "id": "log_observability",
              "type": "storage_write",
              "fields": [
                "run_id",
                "event_id",
                "trace_id",
                "segment",
                "score",
                "play",
                "approval_status",
                "retry_count"
              ]
            }
          ]
        },
        {
          "name": "blocked",
          "condition": "approval_status != 'approved'",
          "actions": [
            {
              "id": "emit_blocked_event",
              "type": "webhook_post",
              "url": "https://events.internal/emit",
              "payload": {
                "event_type": "nrr.play.blocked",
                "event_id": "{{event_id}}",
                "reason": "approval_rejected_or_timeout"
              }
            },
            {
              "id": "log_observability",
              "type": "storage_write",
              "fields": [
                "run_id",
                "event_id",
                "trace_id",
                "segment",
                "score",
                "play",
                "approval_status",
                "retry_count"
              ]
            }
          ]
        }
      ]
    }
  ],
  "zapier_runtime_constraints": {
    "paths": {
      "max_path_branches_per_group": 10,
      "max_nested_path_steps_per_zap": 3,
      "execution": "sequential_left_to_right",
      "must_be_final_step": true
    },
    "filters": {
      "consume_tasks": false,
      "replay_supported": false
    },
    "code": {
      "javascript_runtime": "nodejs_22",
      "io_limit_mb": 6,
      "plan_specific_limits": {
        "free": {
          "runtime_seconds": 1,
          "requests": "10_per_60_seconds"
        },
        "trial": {
          "runtime_seconds": 10,
          "requests": "75_per_10_seconds"
        },
        "professional_team": {
          "runtime_seconds": 30,
          "requests": "225_per_10_seconds"
        },
        "enterprise": {
          "runtime_seconds": 120,
          "requests": "225_per_10_seconds"
        }
      }
    },
    "webhooks": {
      "catch_raw_hook_max_mb": 2,
      "max_trigger_payload_mb": 10,
      "max_action_payload_mb": 5,
      "rate_limit": {
        "requests_per_5_minutes_per_user": 20000,
        "legacy_requests_per_5_minutes_per_zap": 1000
      }
    },
    "replay": {
      "max_autoreplay_attempts": 5,
      "attempt_cadence": [
        "plus_5m",
        "plus_30m",
        "plus_1h",
        "plus_3h",
        "plus_6h"
      ],
      "replay_window_days": 60
    },
    "templates": {
      "classic_template_includes_values": false,
      "classic_template_supports_code_steps": false,
      "guided_templates_include_values": true
    },
    "import_export": {
      "team_or_enterprise_required": true,
      "json_only": true,
      "non_admin_export_scope": "owned_zaps_only",
      "admin_export_scope": "all_account_zaps"
    }
  },
  "retries": {
    "context_fetch": 3,
    "approval_transport": 2,
    "sfdc_write": 1
  }
}
