{
  "workflow_name": "nrr_machine_low_no_touch",
  "machine_id": "nrr-machine",
  "version": "1.2.0",
  "tray_runtime": {
    "project": "nrr-machine",
    "triggers": [
      {
        "type": "callable",
        "name": "nrr_event_ingest",
        "operation": "trigger_and_respond"
      },
      {
        "type": "scheduled",
        "name": "nrr_periodic_sweep",
        "operation": "cron",
        "cron": "0 */6 * * *",
        "timezone": "America/Los_Angeles",
        "enabled": true
      }
    ]
  },
  "contract": {
    "input_schema": "gtm_event_v1",
    "idempotency_key": "event_id",
    "approval_required_before_side_effects": true,
    "account_segments": [
      "low_touch",
      "no_touch"
    ]
  },
  "steps": [
    {
      "key": "normalize_validate",
      "operation": "script",
      "language": "javascript",
      "notes": "Normalize event payload and derive trace/event identifiers."
    },
    {
      "key": "idempotency_get",
      "operation": "data_storage.get_value",
      "input": {
        "scope": "project",
        "key": "nrr-machine:${steps.normalize_validate.output.event_id}",
        "default": null
      }
    },
    {
      "key": "branch_if_new",
      "operation": "branch",
      "branches": [
        {
          "name": "new",
          "condition": "steps.idempotency_get.output == null"
        },
        {
          "name": "duplicate",
          "condition": "steps.idempotency_get.output != null"
        }
      ]
    },
    {
      "key": "context_enrichment_cog",
      "branch": "new",
      "operation": "call_workflow",
      "mode": "fire_and_wait_for_response",
      "workflow": "shared_context_enrichment",
      "input": {
        "event": "${steps.normalize_validate.output}",
        "providers": [
          "endgame_mcp",
          "salesforce_headless_360",
          "gong",
          "zoom",
          "telemetry",
          "billing"
        ]
      }
    },
    {
      "key": "nrr_scoring_cog",
      "branch": "new",
      "operation": "call_workflow",
      "mode": "fire_and_wait_for_response",
      "workflow": "shared_nrr_scoring",
      "input": {
        "event": "${steps.normalize_validate.output}",
        "context": "${steps.context_enrichment_cog.output}"
      }
    },
    {
      "key": "segment_gate",
      "branch": "new",
      "operation": "boolean_condition",
      "condition": "steps.nrr_scoring_cog.output.segment in ['low_touch','no_touch']"
    },
    {
      "key": "play_selection_cog",
      "branch": "new",
      "operation": "call_workflow",
      "mode": "fire_and_wait_for_response",
      "workflow": "shared_play_selection",
      "input": {
        "score": "${steps.nrr_scoring_cog.output}",
        "context": "${steps.context_enrichment_cog.output}"
      }
    },
    {
      "key": "draft_outbound_cog",
      "branch": "new",
      "operation": "call_workflow",
      "mode": "fire_and_wait_for_response",
      "workflow": "shared_outbound_drafting",
      "input": {
        "play": "${steps.play_selection_cog.output}",
        "context": "${steps.context_enrichment_cog.output}"
      }
    },
    {
      "key": "approval_loop_cog",
      "branch": "new",
      "operation": "call_workflow",
      "mode": "fire_and_wait_for_response",
      "workflow": "shared_approval_loop",
      "input": {
        "machine_id": "nrr-machine",
        "event_id": "${steps.normalize_validate.output.event_id}",
        "actions": [
          "send_outbound_email",
          "salesforce.update_record"
        ],
        "proposal": "${steps.draft_outbound_cog.output}",
        "timeout_seconds": 1800
      }
    },
    {
      "key": "approval_branch",
      "branch": "new",
      "operation": "branch",
      "branches": [
        {
          "name": "approved",
          "condition": "steps.approval_loop_cog.output.approval_status == 'approved'"
        },
        {
          "name": "blocked",
          "condition": "steps.approval_loop_cog.output.approval_status != 'approved'"
        }
      ]
    },
    {
      "key": "send_outbound",
      "branch": "approved",
      "operation": "send_email",
      "error_handling": "manual",
      "input": {
        "to": "${steps.draft_outbound_cog.output.to}",
        "subject": "${steps.draft_outbound_cog.output.subject}",
        "body": "${steps.draft_outbound_cog.output.body}"
      }
    },
    {
      "key": "update_sfdc",
      "branch": "approved",
      "operation": "salesforce.update_record",
      "error_handling": "manual",
      "input": {
        "object": "Opportunity",
        "record_id": "${steps.normalize_validate.output.attributes.opportunity_id}",
        "fields": "${steps.play_selection_cog.output.crm_updates}",
        "external_idempotency": "${steps.normalize_validate.output.event_id}"
      }
    },
    {
      "key": "emit_terminal",
      "branch": "new",
      "operation": "http.client",
      "input": {
        "method": "POST",
        "url": "https://events.internal/emit",
        "body": {
          "event_type": "${steps.approval_loop_cog.output.approval_status == 'approved' ? 'nrr.play.executed' : 'nrr.play.blocked'}",
          "trace": "${steps.normalize_validate.output.trace}",
          "subject": "${steps.normalize_validate.output.subject}",
          "attributes": {
            "segment": "${steps.nrr_scoring_cog.output.segment}",
            "score": "${steps.nrr_scoring_cog.output.score}",
            "approval_status": "${steps.approval_loop_cog.output.approval_status}"
          }
        }
      }
    },
    {
      "key": "idempotency_set",
      "branch": "new",
      "operation": "data_storage.set_value",
      "input": {
        "scope": "project",
        "key": "nrr-machine:${steps.normalize_validate.output.event_id}",
        "value": {
          "status": "completed",
          "approval_status": "${steps.approval_loop_cog.output.approval_status}",
          "updated_at": "${meta.now}"
        }
      }
    },
    {
      "key": "response_duplicate",
      "branch": "duplicate",
      "operation": "callable_workflow_response",
      "body": {
        "event_type": "nrr.play.duplicate_ignored",
        "status": "ignored"
      }
    },
    {
      "key": "response_new",
      "branch": "new",
      "operation": "callable_workflow_response",
      "body": {
        "event_type": "${steps.approval_loop_cog.output.approval_status == 'approved' ? 'nrr.play.executed' : 'nrr.play.blocked'}",
        "trace": "${steps.normalize_validate.output.trace}",
        "attributes": {
          "approval_status": "${steps.approval_loop_cog.output.approval_status}",
          "segment": "${steps.nrr_scoring_cog.output.segment}"
        }
      }
    }
  ],
  "error_handling": {
    "default_step_mode": "automatic",
    "manual_paths_for": [
      "send_outbound",
      "update_sfdc"
    ],
    "dead_letter_target": "shared_dead_letter_handler",
    "alerting_payload_fields": [
      "workflow_uuid",
      "step_name",
      "step_log_url",
      "trace_id",
      "message"
    ]
  }
}
