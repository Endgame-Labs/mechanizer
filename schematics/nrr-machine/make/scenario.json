{
  "name": "nrr-machine-low-no-touch-v2",
  "machine_id": "nrr-machine",
  "artifact_type": "make_scenario_blueprint_reference",
  "make_runtime": {
    "blueprint": {
      "max_import_size_mb": 2
    },
    "scheduling": {
      "mode": "immediate_webhook_plus_periodic_rescore",
      "event_webhook_path": "nrr-events",
      "periodic_rescore_interval_hours": 6,
      "max_runs_per_minute": 30,
      "use_sequential_processing": true
    },
    "webhooks": {
      "default_processing_mode": "parallel_for_instant_webhooks",
      "queue_behavior": "per_webhook_queue",
      "documented_rate_limit": "up_to_300_requests_per_10_seconds",
      "scheduled_processing_behavior": "drain_queue_by_max_results_or_cycles_per_run"
    },
    "retry_model": {
      "store_incomplete_executions": true,
      "auto_retry_enabled_for": [
        "RateLimitError",
        "ConnectionError",
        "ModuleTimeoutError"
      ],
      "exponential_backoff_schedule": [
        "1m",
        "10m",
        "10m",
        "30m",
        "30m",
        "30m",
        "3h",
        "3h"
      ],
      "parallel_incomplete_execution_retries_per_scenario": 3
    },
    "history_and_versioning": {
      "manual_version_history_window_days": 60,
      "run_replay_available": true,
      "run_replay_consumes_credits": true
    }
  },
  "flow": [
    {
      "id": 1,
      "module": "webhooks:customWebhook",
      "name": "Receive GTM Event",
      "parameters": {
        "path": "nrr-events"
      }
    },
    {
      "id": 2,
      "module": "json:parseJSON",
      "name": "Parse Payload"
    },
    {
      "id": 3,
      "module": "tools:validator",
      "name": "Validate gtm_event_v1",
      "parameters": {
        "required": [
          "event_id",
          "event_type",
          "source",
          "occurred_at",
          "subject.id"
        ]
      }
    },
    {
      "id": 4,
      "module": "flow:filter",
      "name": "Supported Event Types",
      "filter": "{{event_type}} IN ('account.health_changed','usage.declined','renewal.window_opened')"
    },
    {
      "id": 5,
      "module": "http:makeRequest",
      "name": "Fetch Context",
      "parameters": {
        "url": "https://context.internal/enrich",
        "method": "POST"
      }
    },
    {
      "id": 6,
      "module": "flow:filter",
      "name": "Segment Gate",
      "filter": "{{segment}} IN ('low_touch','no_touch')"
    },
    {
      "id": 7,
      "module": "tools:math",
      "name": "Score Account",
      "parameters": {
        "expression": "round((0.45*health_risk)+(0.35*renewal_risk)+(0.20*expansion_signal))"
      }
    },
    {
      "id": 8,
      "module": "flow:router",
      "name": "Play Router",
      "routes": [
        {
          "name": "Critical",
          "condition": "{{score}} >= 78"
        },
        {
          "name": "Expansion",
          "condition": "{{score}} >= 72 AND {{health_risk}} < 60"
        },
        {
          "name": "Monitor",
          "condition": "default"
        }
      ]
    },
    {
      "id": 9,
      "module": "http:makeRequest",
      "name": "Compose Action Plan",
      "parameters": {
        "url": "https://planner.internal/compose",
        "method": "POST"
      }
    },
    {
      "id": 10,
      "module": "http:makeRequest",
      "name": "Approval Loop",
      "parameters": {
        "url": "https://approval.internal/request",
        "method": "POST",
        "body": {
          "event_id": "{{event_id}}",
          "account_id": "{{subject.id}}",
          "score": "{{score}}",
          "actions": [
            "outbound_email_send",
            "renewal_plan_update"
          ],
          "timeout_seconds": 1800
        }
      }
    },
    {
      "id": 11,
      "module": "flow:router",
      "name": "Approval Router",
      "routes": [
        {
          "name": "Approved",
          "condition": "{{approval_status}} = 'approved'"
        },
        {
          "name": "Blocked",
          "condition": "default"
        }
      ]
    },
    {
      "id": 12,
      "module": "gmail:sendAnEmail",
      "name": "Send Outbound",
      "route": "Approved"
    },
    {
      "id": 13,
      "module": "salesforce:updateARecord",
      "name": "Update Salesforce",
      "route": "Approved",
      "parameters": {
        "object": "Account",
        "idempotency_key": "{{event_id}}"
      }
    },
    {
      "id": 14,
      "module": "http:makeRequest",
      "name": "Emit Executed Event",
      "route": "Approved",
      "parameters": {
        "url": "https://events.internal/emit",
        "method": "POST",
        "body": {
          "event_type": "nrr.play.executed",
          "event_id": "{{event_id}}",
          "score": "{{score}}"
        }
      }
    },
    {
      "id": 15,
      "module": "http:makeRequest",
      "name": "Emit Blocked Event",
      "route": "Blocked",
      "parameters": {
        "url": "https://events.internal/emit",
        "method": "POST",
        "body": {
          "event_type": "nrr.play.blocked",
          "event_id": "{{event_id}}",
          "reason": "approval_rejected_or_timeout"
        }
      }
    },
    {
      "id": 16,
      "module": "datastore:addARecord",
      "name": "Observability Log",
      "parameters": {
        "fields": [
          "run_id",
          "event_id",
          "trace_id",
          "segment",
          "score",
          "play",
          "approval_status",
          "retry_count"
        ]
      }
    }
  ],
  "error_handling": {
    "strategy": "break_with_incomplete_execution_retry_plus_dead_letter",
    "dead_letter": "nrr_machine_dlq"
  }
}
