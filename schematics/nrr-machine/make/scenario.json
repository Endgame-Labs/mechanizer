{
  "name": "nrr-machine-low-no-touch-v3",
  "machine_id": "nrr-machine",
  "artifact_type": "make_scenario_blueprint_reference",
  "make_runtime": {
    "blueprint": {
      "max_import_size_mb": 2
    },
    "scheduling": {
      "mode": "instant_webhook_plus_periodic_rescore",
      "webhook_path": "nrr-events",
      "periodic_rescore_interval_hours": 6,
      "max_runs_per_minute": 30,
      "sequential_processing": true
    },
    "retry_model": {
      "store_incomplete_executions": true,
      "auto_retry_errors": [
        "RateLimitError",
        "ConnectionError",
        "ModuleTimeoutError"
      ],
      "retry_schedule": [
        "1m",
        "10m",
        "10m",
        "30m",
        "30m",
        "30m",
        "3h",
        "3h"
      ]
    }
  },
  "modules": [
    {
      "id": 1,
      "module": "webhooks:customWebhook",
      "name": "Receive GTM Event",
      "parameters": {
        "path": "nrr-events"
      }
    },
    {
      "id": 2,
      "module": "json:createJSON",
      "name": "Normalize gtm_event_v1"
    },
    {
      "id": 3,
      "module": "datastore:getARecord",
      "name": "Idempotency Lookup",
      "parameters": {
        "store": "nrr_runs",
        "key": "nrr:{{2.event_id}}"
      }
    },
    {
      "id": 4,
      "module": "flow:filter",
      "name": "Skip Duplicates",
      "filter": "{{empty(3.value)}}"
    },
    {
      "id": 5,
      "module": "http:makeRequest",
      "name": "Fetch Context",
      "parameters": {
        "url": "https://context.internal/nrr/enrich",
        "method": "POST",
        "body": "{{toJSON(2)}}"
      }
    },
    {
      "id": 6,
      "module": "http:makeRequest",
      "name": "Score Account",
      "parameters": {
        "url": "https://cogs.internal/deal_score_reasoner/v1/execute",
        "method": "POST",
        "body": "{{5.body}}"
      }
    },
    {
      "id": 7,
      "module": "flow:router",
      "name": "Play Router",
      "routes": [
        {
          "name": "critical",
          "condition": "{{6.body.score}} >= 78"
        },
        {
          "name": "expansion",
          "condition": "{{6.body.score}} >= 72 AND {{6.body.health_risk}} < 60"
        },
        {
          "name": "monitor",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 8,
      "module": "tools:iterator",
      "name": "Iterate Proposed Actions",
      "parameters": {
        "array": "{{6.body.recommended_actions}}"
      }
    },
    {
      "id": 9,
      "module": "tools:arrayAggregator",
      "name": "Aggregate Action Package",
      "parameters": {
        "source": "8",
        "target_structure": "actions[]"
      }
    },
    {
      "id": 10,
      "module": "http:makeRequest",
      "name": "Approval Loop",
      "parameters": {
        "url": "https://approval.internal/request",
        "method": "POST",
        "body": "{\"event_id\":\"{{2.event_id}}\",\"account_id\":\"{{2.subject.id}}\",\"actions\":{{9.array}},\"timeout_seconds\":1800}"
      }
    },
    {
      "id": 11,
      "module": "flow:router",
      "name": "Approval Router",
      "routes": [
        {
          "name": "approved",
          "condition": "{{10.body.approval_status}} = approved"
        },
        {
          "name": "blocked",
          "condition": "fallback"
        }
      ]
    },
    {
      "id": 12,
      "module": "gmail:sendAnEmail",
      "name": "Send Outbound",
      "route": "approved"
    },
    {
      "id": 13,
      "module": "salesforce:updateARecord",
      "name": "Update Account",
      "route": "approved",
      "parameters": {
        "object": "Account",
        "record_id": "{{2.subject.id}}"
      }
    },
    {
      "id": 14,
      "module": "http:makeRequest",
      "name": "Emit Outcome Event",
      "parameters": {
        "url": "https://events.internal/emit",
        "method": "POST",
        "body": "{\"event_type\":\"{{if(11.route = \\\"approved\\\"; \\\"nrr.play.executed\\\"; \\\"nrr.play.blocked\\\")}}\",\"event_id\":\"{{2.event_id}}\",\"score\":\"{{6.body.score}}\"}"
      }
    },
    {
      "id": 15,
      "module": "datastore:addOrReplaceARecord",
      "name": "Write Run Summary",
      "parameters": {
        "store": "nrr_runs",
        "key": "nrr:{{2.event_id}}"
      }
    }
  ],
  "error_handlers": [
    {
      "on": [
        "http:makeRequest",
        "gmail:sendAnEmail",
        "salesforce:updateARecord"
      ],
      "strategy": "break_with_incomplete_execution_retry",
      "dead_letter_url": "https://events.internal/dead-letter"
    }
  ]
}
