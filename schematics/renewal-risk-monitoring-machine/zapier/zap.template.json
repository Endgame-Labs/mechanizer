{
  "zap_name": "Renewal Risk Monitoring Machine",
  "version": "1.1.0",
  "machine_id": "renewal-risk-monitoring-machine",
  "description": "Scores renewal risk and routes intervention actions through approval.",
  "trigger": {
    "primary": {
      "app": "schedule_by_zapier",
      "event": "every_day",
      "time": "07:00",
      "timezone": "America/Los_Angeles"
    },
    "alternate": {
      "app": "webhooks_by_zapier",
      "event": "catch_hook",
      "path": "/renewal-risk-monitoring/events"
    }
  },
  "steps": [
    {
      "id": "validate_contract",
      "app": "code_by_zapier",
      "event": "run_javascript"
    },
    {
      "id": "idempotency_lookup",
      "app": "storage_by_zapier",
      "event": "get_value",
      "key_template": "renewal-risk-monitoring:${event_id}"
    },
    {
      "id": "build_recommended_play",
      "app": "webhooks_by_zapier",
      "event": "post",
      "request": {
        "url": "https://planner.internal/compose"
      }
    },
    {
      "id": "notify_csm_slack",
      "app": "slack",
      "event": "send_channel_message"
    },
    {
      "id": "route_exec_alert_if_high",
      "app": "paths_by_zapier",
      "event": "branch",
      "paths": [
        {
          "name": "high",
          "condition": "risk_score >= 80",
          "actions": [
            {
              "app": "slack",
              "event": "send_channel_message"
            }
          ]
        },
        {
          "name": "normal",
          "condition": "risk_score < 80",
          "actions": []
        }
      ]
    },
    {
      "id": "approval_loop",
      "app": "human_in_the_loop",
      "event": "request_approval",
      "fallback": {
        "app": "webhooks_by_zapier",
        "event": "post",
        "url": "https://approval.internal/request"
      }
    },
    {
      "id": "path_on_approval",
      "app": "paths_by_zapier",
      "event": "branch",
      "paths": [
        {
          "name": "approved",
          "condition": "approval_status == 'approved'",
          "actions": [
            {
              "id": "emit_executed",
              "app": "webhooks_by_zapier",
              "event": "post",
              "request": {
                "url": "https://events.internal/emit",
                "json": {
                  "event_type": "renewal.risk.play.executed"
                }
              }
            }
          ]
        },
        {
          "name": "blocked",
          "condition": "approval_status != 'approved'",
          "actions": [
            {
              "id": "emit_blocked",
              "app": "webhooks_by_zapier",
              "event": "post",
              "request": {
                "url": "https://events.internal/emit",
                "json": {
                  "event_type": "renewal.risk.play.blocked"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
