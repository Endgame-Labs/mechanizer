      "module": "tools:validator",
      "name": "Validate gtm_event_v1"
    },
    {
      "id": 3,
      "module": "http:makeRequest",
      "name": "Build Recommended Play",
      "parameters": {
        "url": "https://planner.internal/compose",
        "method": "POST"
      }
    },
    {
      "id": 4,
      "module": "http:makeRequest",
      "name": "CSM Slack Notify",
      "parameters": {
        "url": "https://slack.internal/notify",
        "method": "POST"
      }
    }
  ]
}
