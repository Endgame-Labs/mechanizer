  "make_runtime": {
    "scheduling": {
      "mode": "daily",
      "cron": "0 7 * * *",
      "timezone": "America/Los_Angeles"
    }
  },
  "flow": [
    {
      "id": 1,
      "module": "scheduler:daily",
      "name": "Daily Trigger"
    },
    {
