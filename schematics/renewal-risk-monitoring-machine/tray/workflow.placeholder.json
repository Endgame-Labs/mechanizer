{
  "workflow_name": "renewal_risk_monitoring_daily",
  "machine_id": "renewal-risk-monitoring-machine",
  "trigger": {
    "type": "scheduled",
    "cron": "0 7 * * *",
    "timezone": "America/Los_Angeles"
  },
  "steps": [
    {
      "key": "normalize_validate",
      "operation": "script",
      "script": "validate required gtm_event_v1 keys"
    },
    {
      "key": "build_recommended_play",
      "operation": "http_client",
      "request": {
        "method": "POST",
        "url": "https://planner.internal/compose"
      }
    },
    {
      "key": "notify_csm_slack",
      "operation": "http_client",
      "request": {
        "method": "POST",
        "url": "https://slack.internal/notify"
      }
    },
    {
      "key": "route_exec_alert_if_high",
      "operation": "http_client",
      "request": {
        "method": "POST",
        "url": "https://exec-alert.internal/route"
      }
    },
    {
      "key": "approval_optional_actions",
      "operation": "http_client",
      "request": {
        "method": "POST",
        "url": "https://approval.internal/request"
      }
    }
  ]
}
