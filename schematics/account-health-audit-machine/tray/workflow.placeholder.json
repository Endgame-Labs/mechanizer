{
  "name": "account-health-audit-machine-v1",
  "machine_id": "account-health-audit-machine",
  "version": "1.1.0",
  "trigger": {
    "type": "scheduled_or_callable",
    "scheduled": {
      "operation": "cron",
      "cron": "0 6 * * 1-5",
      "timezone": "America/Los_Angeles"
    },
    "callable": {
      "operation": "trigger_and_respond"
    },
    "input_schema": "gtm_event_v1",
    "accepts_event_types": [
      "audit.run_requested",
      "audit.snapshot_ready"
    ]
  },
  "config": {
    "slo": {
      "p95_end_to_end_seconds": 300
    },
    "idempotency_key": "event_id",
    "approval_required_for_side_effects": true
  },
  "steps": [
    {
      "id": "normalize_validate",
      "type": "script",
      "script": "assert_required_gtm_event_v1_fields"
    },
    {
      "id": "idempotency_get",
      "type": "data_storage.get_value",
      "input": {
        "scope": "project",
        "key": "account-health-audit:${steps.normalize_validate.output.event_id}",
        "default": null
      }
    },
    {
      "id": "branch_if_new",
      "type": "branch",
      "branches": [
        {
          "name": "new",
          "when": "steps.idempotency_get.output == null"
        },
        {
          "name": "duplicate",
          "when": "steps.idempotency_get.output != null"
        }
      ]
    },
    {
      "id": "context_enrichment_cog",
      "branch": "new",
      "type": "call_workflow",
      "operation": "fire_and_wait_for_response",
      "workflow": "shared_context_enrichment",
      "input": {
        "event": "${steps.normalize_validate.output}",
        "providers": [
          "endgame_mcp",
          "salesforce_headless_360",
          "gong_or_zoom",
          "seismic_or_highspot"
        ]
      }
    },
    {
      "id": "health_scoring_cog",
      "branch": "new",
      "type": "call_workflow",
      "operation": "fire_and_wait_for_response",
      "workflow": "shared_health_scoring",
      "input": {
        "event": "${steps.normalize_validate.output}",
        "context": "${steps.context_enrichment_cog.output}"
      }
    },
    {
      "id": "directive_alignment_cog",
      "branch": "new",
      "type": "call_workflow",
      "operation": "fire_and_wait_for_response",
      "workflow": "shared_directive_alignment",
      "input": {
        "analysis": "${steps.health_scoring_cog.output}",
        "context": "${steps.context_enrichment_cog.output}"
      }
    },
    {
      "id": "compose_remediation_cog",
      "branch": "new",
      "type": "call_workflow",
      "operation": "fire_and_wait_for_response",
      "workflow": "shared_remediation_plan",
      "input": {
        "analysis": "${steps.health_scoring_cog.output}",
        "alignment": "${steps.directive_alignment_cog.output}"
      }
    },
    {
      "id": "approval_needed_gate",
      "branch": "new",
      "type": "boolean_condition",
      "condition": "steps.compose_remediation_cog.output.contains_side_effects == true"
    },
    {
      "id": "approval_loop_cog",
      "branch": "new",
      "type": "call_workflow",
      "operation": "fire_and_wait_for_response",
      "workflow": "shared_approval_loop",
      "run_when": "steps.approval_needed_gate.output == true",
      "input": {
        "machine_id": "account-health-audit-machine",
        "event_id": "${steps.normalize_validate.output.event_id}",
        "actions": "${steps.compose_remediation_cog.output.actions}",
        "proposal": "${steps.compose_remediation_cog.output}",
        "timeout_seconds": 1800
      }
    },
    {
      "id": "emit_output_event",
      "branch": "new",
      "type": "http.client",
      "method": "POST",
      "url": "https://events.internal/v1/publish",
      "body_template": {
        "schema_version": "gtm_event_v1",
        "event_id": "${steps.normalize_validate.output.event_id}",
        "event_type": "account.health.audit.completed",
        "source": "tray",
        "trace": "${steps.normalize_validate.output.trace}",
        "subject": "${steps.normalize_validate.output.subject}",
        "attributes": {
          "health_score": "${steps.health_scoring_cog.output.health_score}",
          "risk_level": "${steps.health_scoring_cog.output.risk_level}",
          "approval_status": "${steps.approval_loop_cog.output.approval_status || 'not_required'}",
          "recommended_actions": "${steps.compose_remediation_cog.output.actions}"
        }
      }
    },
    {
      "id": "idempotency_set",
      "branch": "new",
      "type": "data_storage.set_value",
      "input": {
        "scope": "project",
        "key": "account-health-audit:${steps.normalize_validate.output.event_id}",
        "value": {
          "terminal_event_type": "account.health.audit.completed",
          "updated_at": "${meta.now}"
        }
      }
    },
    {
      "id": "response_duplicate",
      "branch": "duplicate",
      "type": "callable_workflow_response",
      "body": {
        "event_type": "account.health.audit.duplicate_ignored",
        "status": "ignored"
      }
    },
    {
      "id": "response_new",
      "branch": "new",
      "type": "callable_workflow_response",
      "body": {
        "event_type": "account.health.audit.completed",
        "trace": "${steps.normalize_validate.output.trace}",
        "attributes": {
          "health_score": "${steps.health_scoring_cog.output.health_score}",
          "risk_level": "${steps.health_scoring_cog.output.risk_level}",
          "approval_status": "${steps.approval_loop_cog.output.approval_status || 'not_required'}"
        }
      }
    }
  ]
}
