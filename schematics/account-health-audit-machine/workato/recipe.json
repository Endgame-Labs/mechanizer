{
  "name": "account-health-audit-machine-v1",
  "machine_id": "account-health-audit-machine",
  "artifact_type": "workato_recipe_reference",
  "contract": {
    "input_contract": "gtm_event_v1",
    "output_contract": "gtm_event_v1",
    "idempotency_key": "event_id",
    "accepted_event_types": [
      "audit.run_requested",
      "audit.snapshot_ready"
    ],
    "approval_required_before_side_effects": false
  },
  "workato_runtime": {
    "recipe_type": "api_recipe_plus_optional_scheduled_recipe",
    "shared_logic": "recipe_functions",
    "state_store": "lookup_tables",
    "promotion": "recipe_lifecycle_management_package",
    "job_replay_supported": true
  },
  "steps": [
    {
      "id": "api_event_trigger",
      "type": "api_platform.new_api_request",
      "name": "Account Health Audit Machine API event",
      "input_schema": "gtm_event_v1",
      "path": "/account-health-audit-machine",
      "accepts_event_types": [
        "audit.run_requested",
        "audit.snapshot_ready"
      ]
    },
    {
      "id": "scheduled_sweep_trigger",
      "type": "scheduled_recipe.trigger",
      "name": "Companion scheduled sweep recipe",
      "cron": "0 6 * * 1-5",
      "timezone": "America/Los_Angeles",
      "purpose": "call the same recipe-function path for periodic sweep/backfill"
    },
    {
      "id": "normalize_validate",
      "type": "tools.javascript",
      "name": "Normalize + validate gtm_event_v1",
      "validates": [
        "event_id",
        "event_type",
        "source",
        "occurred_at",
        "trace.trace_id",
        "subject"
      ]
    },
    {
      "id": "idempotency_lookup",
      "type": "lookup_table.search_rows",
      "name": "Idempotency lookup",
      "key": "account-health-audit-machine:{{normalize_validate.event_id}}",
      "on_duplicate": "stop_job_without_side_effects"
    },
    {
      "id": "enrich_account_health",
      "type": "recipe_function.call_function",
      "name": "enrich_account_health",
      "input": "{{normalize_validate.output}}",
      "timeout_seconds": 60
    },
    {
      "id": "deal_score_reasoner",
      "type": "recipe_function.call_function",
      "name": "deal_score_reasoner",
      "input": "{{normalize_validate.output}}",
      "timeout_seconds": 60
    },
    {
      "id": "directive_alignment",
      "type": "recipe_function.call_function",
      "name": "directive_alignment",
      "input": "{{normalize_validate.output}}",
      "timeout_seconds": 60
    },
    {
      "id": "route_exec_alert",
      "type": "recipe_function.call_function",
      "name": "route_exec_alert",
      "input": "{{normalize_validate.output}}",
      "timeout_seconds": 60
    },
    {
      "id": "compose_action_plan",
      "type": "tools.javascript",
      "name": "Compose action plan",
      "side_effects_considered": [
        "account_health_audit_publish",
        "narrative_digest_send",
        "roadmap_task_upsert"
      ]
    },
    {
      "id": "execute_side_effects",
      "type": "connector_actions",
      "name": "Execute approved/deterministic side effects",
      "side_effects": [
        "account_health_audit_publish",
        "narrative_digest_send",
        "roadmap_task_upsert"
      ],
      "guard": "idempotency_lookup.is_new"
    },
    {
      "id": "emit_terminal_event",
      "type": "http.post",
      "name": "Emit terminal gtm_event_v1",
      "url": "https://events.internal/v1/publish",
      "body": {
        "event_contract": "gtm_event_v1",
        "source": "workato",
        "machine_id": "account-health-audit-machine",
        "trace": "{{normalize_validate.trace}}",
        "attributes": {
          "approval_status": "not_required",
          "workato_job_url": "{{job.url}}"
        }
      }
    },
    {
      "id": "write_run_summary",
      "type": "lookup_table.upsert_row",
      "name": "Write run summary",
      "key": "account-health-audit-machine:{{normalize_validate.event_id}}",
      "value_fields": [
        "status",
        "approval_status",
        "trace_id",
        "workato_job_url",
        "updated_at"
      ]
    }
  ],
  "error_handling": {
    "default_mode": "monitor_and_handle_errors",
    "retryable_error_classes": [
      "RateLimitError",
      "ConnectionError",
      "TimeoutError"
    ],
    "dead_letter": {
      "type": "http.post",
      "url": "https://events.internal/v1/dead-letter",
      "payload_fields": [
        "machine_id",
        "event_id",
        "trace_id",
        "step_name",
        "error_type",
        "error_message",
        "workato_job_url"
      ]
    }
  }
}
