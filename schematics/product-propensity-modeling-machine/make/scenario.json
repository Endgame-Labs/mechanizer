{
  "name": "product-propensity-modeling-machine-v2",
  "machine_id": "product-propensity-modeling-machine",
  "artifact_type": "make_scenario_blueprint_reference",
  "make_runtime": {
    "blueprint": {
      "max_import_size_mb": 2
    },
    "scheduling": {
      "mode": "scheduled_plus_webhook",
      "cron": "0 */6 * * *",
      "timezone": "America/Los_Angeles",
      "max_runs_per_minute": 20,
      "sequential_processing": true
    },
    "retry_model": {
      "store_incomplete_executions": true,
      "auto_retry_errors": [
        "RateLimitError",
        "ConnectionError",
        "ModuleTimeoutError"
      ]
    }
  },
  "modules": [
    {
      "id": 1,
      "module": "scheduler:everyDay",
      "name": "Six-Hour Score Refresh"
    },
    {
      "id": 2,
      "module": "json:createJSON",
      "name": "Normalize gtm_event_v1 + Product ID"
    },
    {
      "id": 3,
      "module": "datastore:getARecord",
      "name": "Idempotency Lookup",
      "parameters": {
        "store": "product_propensity_runs",
        "key": "product-propensity:{{2.event_id}}:{{2.attributes.product_id}}"
      }
    },
    {
      "id": 4,
      "module": "flow:filter",
      "name": "Skip Duplicates",
      "filter": "{{empty(3.value)}}"
    },
    {
      "id": 5,
      "module": "http:makeRequest",
      "name": "Fetch Endgame Propensity Context",
      "parameters": {
        "url": "https://context.internal/endgame/propensity-context",
        "method": "POST",
        "body": "{{toJSON(2)}}"
      }
    },
    {
      "id": 6,
      "module": "http:makeRequest",
      "name": "Run Propensity Score Reasoner",
      "parameters": {
        "url": "https://cogs.internal/propensity_score_reasoner/v1/execute",
        "method": "POST",
        "body": "{{5.body}}"
      }
    },
    {
      "id": 7,
      "module": "http:makeRequest",
      "name": "Directive Alignment",
      "parameters": {
        "url": "https://cogs.internal/directive_alignment/v1/execute",
        "method": "POST",
        "body": "{{6.body}}"
      }
    },
    {
      "id": 8,
      "module": "tools:iterator",
      "name": "Iterate Reason Codes",
      "parameters": {
        "array": "{{7.body.reason_codes}}"
      }
    },
    {
      "id": 9,
      "module": "tools:arrayAggregator",
      "name": "Aggregate Evidence References",
      "parameters": {
        "source": "8",
        "target_structure": "evidence_refs[]"
      }
    },
    {
      "id": 10,
      "module": "http:makeRequest",
      "name": "Emit Scored Event",
      "parameters": {
        "url": "https://events.internal/emit",
        "method": "POST",
        "body": "{\"event_type\":\"product.propensity.scored\",\"event_id\":\"{{2.event_id}}\",\"product_id\":\"{{2.attributes.product_id}}\",\"propensity_score\":\"{{6.body.propensity_score}}\",\"propensity_band\":\"{{6.body.propensity_band}}\",\"evidence_refs\":{{9.array}}}"
      }
    },
    {
      "id": 11,
      "module": "datastore:addOrReplaceARecord",
      "name": "Write Run Summary",
      "parameters": {
        "store": "product_propensity_runs",
        "key": "product-propensity:{{2.event_id}}:{{2.attributes.product_id}}"
      }
    }
  ]
}
